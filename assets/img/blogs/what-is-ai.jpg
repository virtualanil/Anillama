tton-touch-target"></span></button><!----><!----></gem-icon-button><!----><!----><!----><!----></div><!----><!----></div><!----><pre _ngcontent-ng-c427156625="" class="ng-tns-c427156625-32"><code _ngcontent-ng-c427156625="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c427156625-32"><span class="hljs-section">[build]</span>
  <span class="hljs-attr">publish</span> = <span class="hljs-string">"."</span>
</code></pre><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><p data-path-to-node="15,1,2"><i data-path-to-node="15,1,2" data-index-in-node="0">(Netlify le by default clean URLs handle garchha).</i></p></li></ul><h3 data-path-to-node="17">4. Nginx Server (VPS / Dedicated Server)</h3><p data-path-to-node="18">Yadi tapai VPS / Nginx server chalaundai hunuhunchha bhane, Nginx config file (<code data-path-to-node="18" data-index-in-node="79">/etc/nginx/sites-available/default</code>) ko <code data-path-to-node="18" data-index-in-node="118">location /</code> block ma yo thapnuhos:</p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c427156625="" class="ng-tns-c427156625-33 enable-luminous-code-block ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c427156625="" class="code-block ng-tns-c427156625-33 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression,attention;BardVeMetadataKey:[[&quot;r_19038c9756db0500&quot;,&quot;c_85d3c3c486cd93a7&quot;,null,&quot;rc_e2a4863566543a5f&quot;,null,null,&quot;gu-Latn&quot;,null,1,null,null,1,0]]" data-hveid="0" decode-data-ved="1" data-ved="0CAAQhtANahcKEwiThO7SwOOVAxUAAAAAHQAAAAAQOw" style="display: block;"><!----><div _ngcontent-ng-c427156625="" class="formatted-code-block-internal-container ng-tns-c427156625-33"><div _ngcontent-ng-c427156625="" class="animated-opacity ng-tns-c427156625-33"><div _ngcontent-ng-c427156625="" class="code-block-decoration header-formatted gds-emphasized-body-m ng-tns-c427156625-33 ng-star-inserted" style=""><span _ngcontent-ng-c427156625="" class="ng-tns-c427156625-33">Nginx</span><div _ngcontent-ng-c427156625="" class="buttons ng-tns-c427156625-33 ng-star-inserted"><gem-icon-button _ngcontent-ng-c427156625="" tabindex="-1" type="onSurface" size="small" fonticonname="arrow_circle_down" theme="lm" arialabel="Download code" gemtooltip="Download code" class="mat-mdc-tooltip-trigger download-button ng-tns-c427156625-33 gem-button gem-button-badge-size-small gem-button-size-small gem-button-type-on-surface lm-enabled ng-star-inserted" _nghost-ng-c374551268="" aria-describedby="cdk-describedby-message-ng-1-32" cdk-describedby-host="ng-1"><!----><!----><button _ngcontent-ng-c374551268="" maticonbutton="" matbadgeposition="after" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-badge mat-unthemed mat-badge-overlap mat-badge-above mat-badge-after mat-badge-small mat-badge-hidden ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" aria-label="Download code" jslog="305704;track:generic_click,impression"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><gem-icon _ngcontent-ng-c374551268="" _nghost-ng-c818472059=""><mat-icon _ngcontent-ng-c818472059="" role="img" class="mat-icon notranslate lm-icon-l lumi-symbols mat-ligature-font mat-icon-no-color ng-star-inserted" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="arrow_circle_down" data-mat-icon-namespace="lumi-symbols" fonticon="arrow_circle_down"></mat-icon><!----><!----><!----></gem-icon><!----><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><!----></gem-icon-button><!----><!----><!----><!----><!----><gem-icon-button _ngcontent-ng-c427156625="" tabindex="-1" type="onSurface" size="small" fonticonname="copy" theme="lm" arialabel="Copy code" gemtooltip="Copy code" data-test-id="gem-copy-button" class="mat-mdc-tooltip-trigger copy-button ng-tns-c427156625-33 gem-button gem-button-badge-size-small gem-button-size-small gem-button-type-on-surface lm-enabled ng-star-inserted" _nghost-ng-c374551268="" aria-describedby="cdk-describedby-message-ng-1-33" cdk-describedby-host="ng-1"><!----><!----><button _ngcontent-ng-c374551268="" maticonbutton="" matbadgeposition="after" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-badge mat-unthemed mat-badge-overlap mat-badge-above mat-badge-after mat-badge-small mat-badge-hidden ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" aria-label="Copy code" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_19038c9756db0500&quot;,&quot;c_85d3c3c486cd93a7&quot;,null,&quot;rc_e2a4863566543a5f&quot;,null,null,&quot;gu-Latn&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><gem-icon _ngcontent-ng-c374551268="" _nghost-ng-c818472059=""><mat-icon _ngcontent-ng-c818472059="" role="img" class="mat-icon notranslate lm-icon-l lumi-symbols mat-ligature-font mat-icon-no-color ng-star-inserted" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="copy" data-mat-icon-namespace="lumi-symbols" fonticon="copy"></mat-icon><!----><!----><!----></gem-icon><!----><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><!----></gem-icon-button><!----><!----><!----><!----></div><!----><!----></div><!----><pre _ngcontent-ng-c427156625="" class="ng-tns-c427156625-33"><code _ngcontent-ng-c427156625="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c427156625-33"><span class="hljs-attribute">location</span> / {
    <span class="hljs-attribute">try_files</span> $uri $uri/ $uri.html =<span class="hljs-number">404</span>;
}
</code></pre><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><h3 data-path-to-node="21">5. Folder Structure Method (GitHub Pages wa Normal Hosting ko lagi)</h3><p data-path-to-node="22">Yadi mathi ko kunai pani server file modify garna mildayna bhane:</p><ul data-path-to-node="23"><li><p data-path-to-node="23,0,0"><code data-path-to-node="23,0,0" data-index-in-node="0">/Blogs/ai-automation-with-n8n.html</code> ko satta:</p><ol start="1" data-path-to-node="23,0,1"><li><p data-path-to-node="23,0,1,0,0"><code data-path-to-node="23,0,1,0,0" data-index-in-node="0">Blogs</code> folder bhitra <code data-path-to-node="23,0,1,0,0" data-index-in-node="20">ai-automation-with-n8n</code> nam ko euta naya folder banaunuhos.</p></li><li><p data-path-to-node="23,0,1,1,0">Tyo folder bhitra tapai ko file lai <code data-path-to-node="23,0,1,1,0" data-index-in-node="36">index.html</code> nam rakhera save garnuhos.</p></li></ol></li><li><p data-path-to-node="23,1,0">Aba URL auto <code data-path-to-node="23,1,0" data-index-in-node="13">[https://anillama.com.np/Blogs/ai-automation-with-n8n/](https://anillama.com.np/Blogs/ai-automation-with-n8n/)</code> hunchha.</p></li></ul><h3 data-path-to-node="25">⚠️ Dhyan dinuparne kura (Internal Links):</h3><p data-path-to-node="26">Eti garisake pachhi tapai ko HTML code bhitra bhaeko links (<code data-path-to-node="26" data-index-in-node="60">&lt;a&gt;</code> tag) haru bata pani <code data-path-to-node="26" data-index-in-node="84">.html</code> hataunuhos:</p><ul data-path-to-node="27"><li><p data-path-to-node="27,0,0"><b data-path-to-node="27,0,0" data-index-in-node="0">Pahile:</b> <code data-path-to-node="27,0,0" data-index-in-node="8">&lt;a href="/Blogs/ai-automation-with-n8n.html"&gt;</code></p></li><li><p data-path-to-node="27,1,0"><b data-path-to-node="27,1,0" data-index-in-node="0">Aba:</b> <code data-path-to-node="27,1,0" data-index-in-node="5">&lt;a href="/Blogs/ai-automation-with-n8n"&gt;</code></p></li></ul></div></message-content><!----></div></structured-content-container><!----><!----><!----><div _ngcontent-ng-c815380038="" class="response-footer has-thoughts gap complete"><!----><!----><!----><sources-list _ngcontent-ng-c815380038="" class="sources-list ng-star-inserted"><!----></sources-list><!----><election-info-disclaimer _ngcontent-ng-c815380038="" _nghost-ng-c3453717024="" class="ng-star-inserted" style="display: none;"><!----></election-info-disclaimer><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></div></div><!----><!----><sensitive-memories-banner _ngcontent-ng-c815380038="" _nghost-ng-c542676797="" class="ng-star-inserted" style=""><!----></sensitive-memories-banner><!----><!----><!----><!----></div></div><div _ngcontent-ng-c1812237660="" class="response-container-footer ng-tns-c1812237660-15 ng-star-inserted"><!----><!----><!----><message-actions _ngcontent-ng-c815380038="" footer="" class="hide-on-print ng-tns-c145344266-24 ng-star-inserted hide-action-bar" _nghost-ng-c145344266="" style=""><div _ngcontent-ng-c145344266="" class="actions-container-v2 ng-tns-c145344266-24"><div _ngcontent-ng-c145344266="" class="buttons-container-v2 ng-tns-c145344266-24 ng-star-inserted"><thumb-up-button _ngcontent-ng-c145344266="" _nghost-ng-c614561925="" class="ng-tns-c145344266-24 luminous-theme ng-star-inserted"><gem-icon-button _ngcontent-ng-c614561925="" tabindex="-1" theme="lm" type="onSurface"