  <span class="hljs-attr">"cleanUrls"</span>: <span class="hljs-literal">true</span>
}
</code></pre><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><h3 data-path-to-node="13">3. Netlify Hosting</h3><p data-path-to-node="14">Yadi <b data-path-to-node="14" data-index-in-node="5">Netlify</b> use gardai hunuhunchha bhane:</p><ul data-path-to-node="15"><li><p data-path-to-node="15,0,0"><b data-path-to-node="15,0,0" data-index-in-node="0">Method 1:</b> Netlify Dashboard ma gayera <b data-path-to-node="15,0,0" data-index-in-node="38">Site settings</b> &gt; <b data-path-to-node="15,0,0" data-index-in-node="54">Build &amp; deploy</b> &gt; <b data-path-to-node="15,0,0" data-index-in-node="71">Post-processing</b> &gt; <b data-path-to-node="15,0,0" data-index-in-node="89">Pretty URLs</b> lai enable/check garnuhos.</p></li><li><p data-path-to-node="15,1,0"><b data-path-to-node="15,1,0" data-index-in-node="0">Method 2:</b> Root folder ma <code data-path-to-node="15,1,0" data-index-in-node="25">netlify.toml</code> file banayera yo lekhnuhos:</p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c427156625="" class="ng-tns-c427156625-32 enable-luminous-code-block ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c427156625="" class="code-block ng-tns-c427156625-32 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression,attention;BardVeMetadataKey:[[&quot;r_19038c9756db0500&quot;,&quot;c_85d3c3c486cd93a7&quot;,null,&quot;rc_e2a4863566543a5f&quot;,null,null,&quot;gu-Latn&quot;,null,1,null,null,1,0]]" data-hveid="0" decode-data-ved="1" data-ved="0CAAQhtANahcKEwiThO7SwOOVAxUAAAAAHQAAAAAQOg" style="display: block;"><!----><div _ngcontent-ng-c427156625="" class="formatted-code-block-internal-container ng-tns-c427156625-32"><div _ngcontent-ng-c427156625="" class="animated-opacity ng-tns-c427156625-32"><div _ngcontent-ng-c427156625="" class="code-block-decoration header-formatted gds-emphasized-body-m ng-tns-c427156625-32 ng-star-inserted" style=""><span _ngcontent-ng-c427156625="" class="ng-tns-c427156625-32">Ini, TOML</span><div _ngcontent-ng-c427156625="" class="buttons ng-tns-c427156625-32 ng-star-inserted"><gem-icon-button _ngcontent-ng-c427156625="" tabindex="-1" type="onSurface" size="small" fonticonname="arrow_circle_down" theme="lm" arialabel="Download code" gemtooltip="Download code" class="mat-mdc-tooltip-trigger download-button ng-tns-c427156625-32 gem-button gem-button-badge-size-small gem-button-size-small gem-button-type-on-surface lm-enabled ng-star-inserted" _nghost-ng-c374551268="" aria-describedby="cdk-describedby-message-ng-1-32" cdk-describedby-host="ng-1"><!----><!----><button _ngcontent-ng-c374551268="" maticonbutton="" matbadgeposition="after" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-badge mat-unthemed mat-badge-overlap mat-badge-above mat-badge-after mat-badge-small mat-badge-hidden ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" aria-label="Download code" jslog="305704;track:generic_click,impression"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><gem-icon _ngcontent-ng-c374551268="" _nghost-ng-c818472059=""><mat-icon _ngcontent-ng-c818472059="" role="img" class="mat-icon notranslate lm-icon-l lumi-symbols mat-ligature-font mat-icon-no-color ng-star-inserted" aria-hidden="true" data-mat-icon-ty